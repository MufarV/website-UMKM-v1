{
  "entities": {
    "transactions": {
      "title": "Transaksi Keuangan",
      "description": "Log pamasukan dan pengeluaran UMKM.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" }
      },
      "required": ["date", "amount", "type"]
    },
    "inventory": {
      "title": "Inventaris Barang",
      "description": "Manajemen stok bahan baku dan produk jadi.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "stock": { "type": "number" },
        "unit": { "type": "string" },
        "minStock": { "type": "number" },
        "price": { "type": "number" }
      },
      "required": ["name", "stock", "unit"]
    },
    "assets": {
      "title": "Sarana & Prasarana",
      "description": "Aset fisik bisnis dan kondisi pemeliharaannya.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "maintenance", "retired"] },
        "lastMaintenance": { "type": "string" },
        "location": { "type": "string" }
      },
      "required": ["name", "status"]
    },
    "accounts": {
      "title": "Daftar Akun (COA)",
      "description": "Bagan akun untuk pembukuan.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Asset", "Liability", "Equity", "Revenue", "Expense"] },
        "balance": { "type": "number" }
      },
      "required": ["code", "name", "type"]
    },
    "journal_entries": {
      "title": "Jurnal Umum",
      "description": "Log transaksi akuntansi double-entry.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "items": { "type": "array" }
      },
      "required": ["date", "description", "items"]
    },
    "employees": {
      "title": "Data Karyawan",
      "description": "Daftar staf atau karyawan UMKM.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "On Leave", "Inactive"] },
        "email": { "type": "string" }
      },
      "required": ["name", "role", "status"]
    },
    "tasks": {
      "title": "Manajemen Tugas",
      "description": "Tugas atau pekerjaan yang didelegasikan.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "assigneeId": { "type": "string" },
        "projectId": { "type": "string" },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "status": { "type": "string", "enum": ["Todo", "In Progress", "Done"] },
        "deadline": { "type": "string", "format": "date" }
      },
      "required": ["title", "status"]
    },
    "projects": {
      "title": "Manajemen Proyek",
      "description": "Proyek besar yang memiliki beberapa tugas.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Completed", "On Hold"] },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" }
      },
      "required": ["name", "status"]
    },
    "planning": {
      "title": "Perencanaan Bisnis (Planning)",
      "description": "Dokumen perencanaan strategis POAC.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "vision": { "type": "string" },
        "mission": { "type": "string" },
        "financialTargets": { "type": "array" },
        "nonFinancialTargets": { "type": "array" },
        "swot": { "type": "object" },
        "strategies": { "type": "array" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "divisions": {
      "title": "Divisi Organisasi",
      "description": "Daftar divisi dalam struktur organisasi.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "employeeIds": { "type": "array" }
      },
      "required": ["name"]
    },
    "production_plans": {
      "title": "Production Plans",
      "description": "Daily production plan notes.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "notes": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      },
      "required": ["date", "notes"]
    },
    "production_logs": {
      "title": "Production Logs",
      "description": "Daily production logs/history.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "itemId": { "type": "string" },
        "itemName": { "type": "string" },
        "quantityChange": { "type": "number" },
        "type": { "type": "string" },
        "note": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      },
      "required": ["date", "itemId", "quantityChange", "type"]
    },
    "production_products": {
      "title": "Produk",
      "description": "Daftar produk dengan kategori fix dan pengembangan.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["Fix", "Pengembangan"] },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      },
      "required": ["name", "category"]
    },
    "sarpra_assets": {
      "title": "Sarpra Assets",
      "description": "Company physical assets and equipment.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownership": { "type": "string" },
        "quantity": { "type": "number" },
        "status": { "type": "string" },
        "icon": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      },
      "required": ["name", "ownership", "quantity", "status"]
    },
    "sarpra_logs": {
      "title": "Sarpra Logs",
      "description": "Service and maintenance logs for assets.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "assetId": { "type": "string" },
        "date": { "type": "string" },
        "notes": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "object" }
      },
      "required": ["assetId", "date", "notes"]
    },
    "pesanan": {
      "title": "Pesanan Online",
      "description": "Pesanan masuk dari website publik.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "customerName": { "type": "string" },
        "status": { "type": "string", "enum": ["Baru", "Selesai", "Dibatalkan"] },
        "tanggal_po": { "type": "string" },
        "waktu_po": { "type": "string" },
        "items": { "type": "string" },
        "totalHarga": { "type": "number" },
        "totalPcs": { "type": "number" },
        "paymentMethod": { "type": "string" }
      }
    },
    "marketing_journey": {
      "title": "Customer Journey",
      "description": "Statistik funnel pemasaran dan catatan analisis.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "awareness": { "type": "number" },
        "interest": { "type": "number" },
        "action": { "type": "number" },
        "retention": { "type": "number" },
        "advocacy": { "type": "number" },
        "awarenessNotes": { "type": "string" },
        "interestNotes": { "type": "string" },
        "actionNotes": { "type": "string" },
        "retentionNotes": { "type": "string" },
        "advocacyNotes": { "type": "string" },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      }
    },
    "marketing_calendar": {
      "title": "Marketing Calendar",
      "description": "Catatan pemasaran harian.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "date": { "type": "string" },
        "note": { "type": "string" },
        "longNote": { "type": "string" },
        "isHighlighted": { "type": "boolean" },
        "type": { "type": "string", "enum": ["idea", "reminder", "highlight"] },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      },
      "required": ["date", "note", "ownerId"]
    },
    "marketing_stp": {
      "title": "Marketing STP",
      "description": "Segmentasi, Targeting, dan Positioning",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "segmentasi": { "type": "string" },
        "targeting": { "type": "string" },
        "positioning": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      },
      "required": ["ownerId"]
    }
  },
  "firestore": {
    "/transactions/{transactionId}": {
      "schema": "transactions",
      "description": "Koleksi data transaksi keuangan."
    },
    "/inventory/{itemId}": {
      "schema": "inventory",
      "description": "Koleksi data inventaris barang."
    },
    "/assets/{assetId}": {
      "schema": "assets",
      "description": "Koleksi data aset fisik UMKM."
    },
    "/accounts/{accountId}": {
      "schema": "accounts",
      "description": "Koleksi bagan akun."
    },
    "/journal_entries/{entryId}": {
      "schema": "journal_entries",
      "description": "Koleksi jurnal umum."
    },
    "/employees/{employeeId}": {
      "schema": "employees",
      "description": "Koleksi data karyawan."
    },
    "/tasks/{taskId}": {
      "schema": "tasks",
      "description": "Koleksi tugas dan proyek."
    },
    "/projects/{projectId}": {
      "schema": "projects",
      "description": "Koleksi proyek utama."
    },
    "/planning/{planningId}": {
      "schema": "planning",
      "description": "Koleksi data perencanaan strategis."
    },
    "/divisions/{divisionId}": {
      "schema": "divisions",
      "description": "Koleksi data divisi organisasi."
    },
    "/production_plans/{planId}": {
      "schema": "production_plans",
      "description": "Daily production plan notes."
    },
    "/production_logs/{logId}": {
      "schema": "production_logs",
      "description": "Daily production logs/history."
    },
    "/production_products/{productId}": {
      "schema": "production_products",
      "description": "Koleksi data produk."
    },
    "/sarpra_assets/{assetId}": {
      "schema": "sarpra_assets",
      "description": "Company physical assets and equipment."
    },
    "/sarpra_logs/{logId}": {
      "schema": "sarpra_logs",
      "description": "Service and maintenance logs for assets."
    },
    "/pesanan/{orderId}": {
      "schema": "pesanan",
      "description": "Koleksi pesanan masuk."
    },
    "/marketing_journey/{journeyId}": {
      "schema": "marketing_journey",
      "description": "Statistik funnel pemasaran."
    },
    "/marketing_calendar/{noteId}": {
      "schema": "marketing_calendar",
      "description": "Catatan pemasaran harian."
    },
    "/marketing_stp/{stpId}": {
      "schema": "marketing_stp",
      "description": "Segmentasi, Targeting, dan Positioning"
    }
  }
}
