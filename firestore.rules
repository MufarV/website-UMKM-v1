rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(resourceData) {
      return isSignedIn() && resourceData.ownerId == request.auth.uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Entity Validations
    function isValidTransaction(data) {
      return data.keys().hasAll(['ownerId', 'amount', 'type', 'date', 'category', 'createdAt', 'updatedAt']) &&
             data.keys().size() <= 10 &&
             data.ownerId == request.auth.uid &&
             data.amount is number && data.amount > 0 &&
             data.type in ['income', 'expense'] &&
             data.date is timestamp &&
             data.category is string && data.category.size() <= 50 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidInventory(data) {
      return data.keys().hasAll(['ownerId', 'name', 'stock', 'unit', 'createdAt', 'updatedAt']) &&
             data.keys().size() <= 10 &&
             data.ownerId == request.auth.uid &&
             data.name is string && data.name.size() <= 100 &&
             data.stock is number && data.stock >= 0 &&
             data.unit is string && data.unit.size() <= 20;
    }

    function isValidAsset(data) {
      return data.keys().hasAll(['ownerId', 'name', 'status', 'location', 'createdAt', 'updatedAt']) &&
             data.keys().size() <= 10 &&
             data.ownerId == request.auth.uid &&
             data.name is string && data.name.size() <= 100 &&
             data.status in ['active', 'maintenance', 'retired'] &&
             data.location is string && data.location.size() <= 200;
    }

    function isValidDivision(data) {
      return data.keys().hasAll(['ownerId', 'name']) &&
             data.ownerId == request.auth.uid &&
             data.name is string && data.name.size() <= 100;
    }

    // 3. Match Blocks
    match /transactions/{transactionId} {
      allow get: if isOwner(existing());
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(transactionId) && isValidTransaction(incoming()) && 
                    incoming().date == request.time && 
                    incoming().createdAt == request.time;
      allow update: if isOwner(existing()) && isValidTransaction(incoming()) && 
                    incoming().ownerId == existing().ownerId &&
                    incoming().updatedAt == request.time &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'description', 'category', 'type', 'updatedAt']);
      allow delete: if isOwner(existing());
    }

    match /inventory/{itemId} {
      allow get: if isOwner(existing());
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(itemId) && isValidInventory(incoming());
      allow update: if isOwner(existing()) && isValidInventory(incoming()) &&
                    incoming().ownerId == existing().ownerId &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['stock', 'price', 'name', 'minStock']);
      allow delete: if isOwner(existing());
    }

    match /assets/{assetId} {
      allow get: if isOwner(existing());
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(assetId) && isValidAsset(incoming());
      allow update: if isOwner(existing()) && isValidAsset(incoming()) &&
                    incoming().ownerId == existing().ownerId &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['status', 'location', 'lastMaintenance', 'updatedAt']);
      allow delete: if isOwner(existing());
    }

    match /accounts/{accountId} {
      allow get: if isOwner(existing());
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(accountId);
      allow update: if isOwner(existing());
      allow delete: if isOwner(existing());
    }

    match /journal_entries/{entryId} {
      allow get: if isOwner(existing());
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(entryId);
      allow update: if isOwner(existing());
      allow delete: if isOwner(existing());
    }

    match /employees/{employeeId} {
      allow get: if isOwner(existing());
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(employeeId);
      allow update: if isOwner(existing());
      allow delete: if isOwner(existing());
    }

    match /tasks/{taskId} {
      allow get: if isOwner(existing());
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(taskId);
      allow update: if isOwner(existing());
      allow delete: if isOwner(existing());
    }

    match /projects/{projectId} {
      allow get: if isOwner(existing());
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(projectId);
      allow update: if isOwner(existing());
      allow delete: if isOwner(existing());
    }

    match /planning/{planningId} {
      allow get: if isOwner(existing());
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(planningId);
      allow update: if isOwner(existing());
      allow delete: if isOwner(existing());
    }

    match /divisions/{divisionId} {
      allow get: if isOwner(existing());
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(divisionId) && isValidDivision(incoming());
      allow update: if isOwner(existing()) && isValidDivision(incoming()) &&
                    incoming().ownerId == existing().ownerId;
      allow delete: if isOwner(existing());
    }
  }
}
